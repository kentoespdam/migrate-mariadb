# PySync-Maria Configuration Template

# Source Host (Host A - Sumber Data)
SOURCE__HOST=localhost
SOURCE__PORT=3306
SOURCE__USER=root
SOURCE__PASSWORD=your_password
SOURCE__DATABASE=your_database
SOURCE__CHARSET=utf8mb4
SOURCE__CONNECT_TIMEOUT=10

# Target Host (Host B - Tujuan Data)
TARGET__HOST=remotehost
TARGET__PORT=3306
TARGET__USER=root
TARGET__PASSWORD=your_password
TARGET__DATABASE=your_database
TARGET__CHARSET=utf8mb4
TARGET__CONNECT_TIMEOUT=10

# Global Settings
BATCH_SIZE=5000
DRY_RUN=false
